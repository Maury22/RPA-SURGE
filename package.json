{
  "name": "robot-sssalud",
  "version": "1.0.0",
  "description": "Robot automatizado para SSSalud",
  "main": "main_18Marzo.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "build": {
    "appId": "com.oficina.robotsssalud",
    "productName": "Robot SSSalud",
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Robot SSSalud"
    },
    "asar": true,
    "asarUnpack": [
      "poppler/**/*"
    ]
  },
  "dependencies": {
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "puppeteer": "^22.0.0",
    "tesseract.js": "^5.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.13.3",
    "electron-packager": "^17.1.2"
  }
}
